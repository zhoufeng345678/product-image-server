# 商品主图生成器 - 环境变量配置示例
GPT_IMAGE_API_KEY=your_api_key_here
API_STRATEGY=mxapi

# 阿里云OSS配置（可选）
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your_oss_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_oss_key_secret
ALIYUN_OSS_BUCKET_NAME=your_bucket
ALIYUN_OSS_DOMAIN=https://your-bucket.oss-cn-beijing.aliyuncs.com

# 阿里云百炼 DashScope
DASHSCOPE_API_KEY=sk-your_dashscope_key
DASHSCOPE_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_MODEL=qwen-plus

# 服务器
PORT=3010
NODE_ENV=production
